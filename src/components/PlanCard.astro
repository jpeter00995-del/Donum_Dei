---
// === 1. IMPORTS ===
import type { Plant, Locale } from '@/lib/types';
import { type RecommendedPlant, estimateAreaSqm } from '@/lib/gardenPlan';
import { t } from '@/lib/i18n';

// === 2. PROPS ===
interface Props {
  plant: Plant;
  rec: RecommendedPlant;
  locale: Locale;
}
const { plant, rec, locale } = Astro.props;

// === 3. DERIVED LABELS (klarere Mengen + Platzbedarf, Welle D.1) ===
const moreLabel = locale === 'de' ? 'Mehr erfahren' : 'Learn more';
const notes = locale === 'de' ? rec.notes_de : rec.notes_en;
const areaSqm = Math.round(estimateAreaSqm(rec, plant) * 10) / 10;
const areaLabel = areaSqm > 0
  ? t(locale, 'plan.card.space', { area: areaSqm.toLocaleString(locale === 'de' ? 'de-DE' : 'en-US') })
  : '';
const qtyHeadline = rec.quantity === 1
  ? t(locale, 'plan.card.qty_one')
  : t(locale, 'plan.card.qty_many', { n: rec.quantity });
---

<article class="plan-card group bg-white border border-slate-200 rounded-lg overflow-hidden hover:border-emerald-400 hover:shadow-md transition flex flex-col">
  <a href={`/${locale}/plant/${plant.slug}`} class="block aspect-[4/3] bg-slate-100 overflow-hidden">
    <img
      src={`/images/plants/${plant.image.filename}`}
      alt={plant.image.alt[locale]}
      title={`© ${plant.image.author} · ${plant.image.license}`}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
      loading="lazy"
    />
  </a>
  <div class="p-4 flex-1 flex flex-col gap-2">
    <header>
      <h3 class="text-lg font-serif font-semibold text-slate-900 leading-tight">
        {plant.names[locale]}
      </h3>
      <p class="text-xs italic text-slate-500">{plant.names.latin}</p>
    </header>

    <!-- Klare Mengen + Platz pro Karte (statt nur "12× STÜCK") -->
    <div class="flex items-baseline gap-2">
      <span class="text-2xl font-bold text-emerald-700">{rec.quantity}×</span>
      <span class="text-sm font-medium text-slate-700">{qtyHeadline}</span>
    </div>
    {areaLabel && (
      <p class="text-xs text-slate-500" aria-label={areaLabel}>
        <span aria-hidden="true">📐 </span>{areaLabel}
      </p>
    )}

    <p class="text-sm text-slate-700 flex-1">{notes}</p>

    <a
      href={`/${locale}/plant/${plant.slug}`}
      class="mt-2 text-sm text-emerald-700 font-medium hover:underline self-start no-print"
    >
      {moreLabel} →
    </a>
  </div>
</article>
