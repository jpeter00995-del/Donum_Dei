---
import { t } from '@/lib/i18n';
import type { UiLocale } from '@/lib/types';

interface Props {
  locale: UiLocale;
}
const { locale } = Astro.props;
---

<footer class="border-t border-slate-200 bg-slate-50 py-6 px-4 text-center text-sm text-slate-600">
  <p class="max-w-2xl mx-auto">{t(locale, 'disclaimer.text')}</p>
</footer>
