---
import '@/styles/global.css';
// Self-hosted fonts (DSGVO — no Google Fonts request from client)
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/crimson-pro/400.css';
import '@fontsource/crimson-pro/600.css';
import '@fontsource/crimson-pro/700.css';
import LanguageToggle from '@/components/LanguageToggle.tsx';
import Disclaimer from '@/components/Disclaimer.astro';
import { t } from '@/lib/i18n';
import { contentLocale } from '@/lib/types';
import type { Locale, UiLocale } from '@/lib/types';

interface Props {
  locale: UiLocale;
  title?: string;
  // Optionale, seiten-eigene Meta-Beschreibung. Ohne Wert: Fallback auf Slogan.
  description?: string;
  // Optionaler Pfad der anderssprachigen Version (z. B. "/en/plant/lavandula-angustifolia").
  // Wenn gesetzt, werden hreflang-Alternates für DE+EN ausgegeben.
  altPath?: string;
  // Optionaler Bildpfad fürs Teilen (z. B. "/images/plants/lavandula.jpg").
  // Ohne Wert: Fallback auf das Favicon.
  imagePath?: string;
}
const { locale, title, description, altPath, imagePath } = Astro.props;
// Menü-/Footer-Links zeigen in die Inhalts-Sprache (DE oder EN). Für Light-
// Sprachen (FR/ES/BG) also auf die englischen Seiten — die Labels bleiben aber
// in der UI-Sprache (t(locale, ...)).
const navLocale = contentLocale(locale);
// Kopfleiste: 1 Direkt-Link (Pflanzen) + 3 Gruppen mit Klapp-Menüs.
// Aus 13 nebeneinander liegenden Links werden 4 ruhige Punkte.
const navGroups: { label: string; items: { href: string; label: string }[] }[] = [
  {
    label: t(locale, 'nav.group_discover'),
    items: [
      { href: navLocale === 'de' ? '/de/suche' : '/en/search', label: t(locale, 'nav.search') },
      { href: navLocale === 'de' ? '/de/hilfe-bei' : '/en/help-with', label: t(locale, 'nav.symptoms') },
      { href: navLocale === 'de' ? '/de/karte' : '/en/map', label: t(locale, 'nav.map') },
      { href: `/${navLocale}/quiz`, label: t(locale, 'nav.quiz') },
    ],
  },
  {
    label: t(locale, 'nav.group_garden'),
    items: [
      { href: navLocale === 'de' ? '/de/mein-garten/' : '/en/my-garden/', label: t(locale, 'nav.garden') },
      { href: navLocale === 'de' ? '/de/kalender' : '/en/calendar', label: t(locale, 'nav.calendar') },
      { href: navLocale === 'de' ? '/de/mischkultur' : '/en/companion-planting', label: t(locale, 'nav.companion') },
      { href: navLocale === 'de' ? '/de/pakete' : '/en/packages', label: t(locale, 'nav.packages') },
      { href: navLocale === 'de' ? '/de/permakultur' : '/en/permaculture', label: t(locale, 'nav.permaculture') },
    ],
  },
  {
    label: t(locale, 'nav.group_themes'),
    items: [
      { href: navLocale === 'de' ? '/de/zuhause-anbauen' : '/en/grow-at-home', label: t(locale, 'nav.indoor') },
      { href: navLocale === 'de' ? '/de/pilze' : '/en/mushrooms', label: t(locale, 'nav.mushrooms') },
      { href: navLocale === 'de' ? '/de/rauschpflanzen' : '/en/psychoactive', label: t(locale, 'nav.controlled') },
    ],
  },
];
const plantsHref = `/${navLocale}/`;
// Ist ein Link der aktuell offenen Seite? (dezentes Hervorheben der aktiven Gruppe)
const pathNoSlash = Astro.url.pathname.replace(/\/+$/, '');
const isActiveHref = (href: string) => pathNoSlash === href.replace(/\/+$/, '');
const isActiveGroup = (items: { href: string }[]) => items.some(i => isActiveHref(i.href));
// Sprach-Leiste im Footer (DE/EN voll, FR/ES/BG Light → Startseite).
const uiLangs: { code: UiLocale; label: string; href: string }[] = [
  { code: 'de', label: 'DE', href: '/de/' },
  { code: 'en', label: 'EN', href: '/en/' },
  { code: 'fr', label: 'FR', href: '/fr/' },
  { code: 'es', label: 'ES', href: '/es/' },
  { code: 'bg', label: 'BG', href: '/bg/' },
];
const pageTitle = title ? `${title} · ${t(locale, 'site.title')}` : t(locale, 'site.title');
// Einzigartige Beschreibung je Seite; auf ~160 Zeichen gekürzt (SEO-Best-Practice).
const rawDescription = (description ?? t(locale, 'site.tagline')).trim();
const metaDescription =
  rawDescription.length > 160 ? rawDescription.slice(0, 157).trimEnd() + '…' : rawDescription;
const currentPath = Astro.url.pathname;
// Kanonische Original-URL dieser Seite (absolut, via konfiguriertem `site`).
const canonicalURL = Astro.site ? new URL(currentPath, Astro.site).href : currentPath;
// Partner-Sprache + absolute URL der anderssprachigen Version (nur wenn altPath gesetzt).
const altLocale: Locale = navLocale === 'de' ? 'en' : 'de';
const altURL = altPath && Astro.site ? new URL(altPath, Astro.site).href : undefined;
// Teilen-Vorschau (Open Graph / Twitter): Seiten-Bild oder Favicon-Fallback.
const ogImagePath = imagePath ?? '/favicon.svg';
const ogImage = Astro.site ? new URL(ogImagePath, Astro.site).href : ogImagePath;
const ogLocale = navLocale === 'de' ? 'de_DE' : 'en_US';
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Google Search Console — Inhaberschafts-Bestätigung (öffentlich, kein Secret) -->
    <meta name="google-site-verification" content="RudDAQpxbeQifsVjbBN3h-P_p3F7IRgbNtRawn9IKII" />
    <title>{pageTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={metaDescription} />
    <link rel="canonical" href={canonicalURL} />
    {altURL && <link rel="alternate" hreflang={locale} href={canonicalURL} />}
    {altURL && <link rel="alternate" hreflang={altLocale} href={altURL} />}
    {altURL && <link rel="alternate" hreflang="x-default" href={canonicalURL} />}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={t(locale, 'site.title')} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="theme-color" content="#047857" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <!-- Google AdSense Loader (Konto pub-5000356216672097). Lädt Googles Werbe-Code;
         Anzeigen erscheinen erst nach Freigabe. Einwilligung via Googles eigenem CMP. -->
    <script is:inline async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5000356216672097" crossorigin="anonymous"></script>
    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js', { scope: '/' }).catch(() => {});
        });
      }
    </script>
  </head>
  <body class="min-h-screen bg-white text-slate-900 flex flex-col font-sans antialiased">
    <header class="border-b border-slate-200 bg-white">
      <div class="max-w-6xl mx-auto px-4 pt-4 pb-3 flex items-center justify-between gap-3">
        <a href={`/${navLocale}/`} class="font-serif text-xl sm:text-2xl md:text-3xl lg:text-4xl font-bold text-slate-900 hover:text-emerald-700 transition tracking-wide whitespace-nowrap">
          {t(locale, 'site.title')}
        </a>
        <LanguageToggle client:load currentLocale={locale} currentPath={currentPath} />
      </div>
      <nav class="border-t border-slate-100 bg-slate-50/60" aria-label="Main">
        <div class="max-w-6xl mx-auto flex flex-wrap items-center justify-center gap-x-1 gap-y-1 px-4 py-2 text-sm text-slate-700">
          <a
            href={plantsHref}
            class:list={[
              'px-3 py-1.5 rounded-md font-medium transition whitespace-nowrap hover:bg-white hover:text-emerald-700',
              isActiveHref(plantsHref) && 'bg-white text-emerald-700',
            ]}
          >{t(locale, 'nav.plants')}</a>
          {navGroups.map(group => (
            <details class="nav-dd relative">
              <summary
                class:list={[
                  'nav-dd-summary flex items-center gap-1 px-3 py-1.5 rounded-md font-medium transition whitespace-nowrap cursor-pointer select-none hover:bg-white hover:text-emerald-700',
                  isActiveGroup(group.items) && 'bg-white text-emerald-700',
                ]}
              >
                {group.label}
                <svg class="nav-dd-caret w-3.5 h-3.5 transition-transform duration-200" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                  <path d="M5.5 7.5 10 12l4.5-4.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </summary>
              <div class="nav-dd-panel absolute left-1/2 -translate-x-1/2 mt-1.5 min-w-[12rem] max-w-[calc(100vw-2rem)] rounded-xl border border-slate-200 bg-white shadow-lg ring-1 ring-black/5 py-1.5 z-30">
                {group.items.map(item => (
                  <a
                    href={item.href}
                    class:list={[
                      'block px-4 py-2 whitespace-nowrap transition hover:bg-emerald-50 hover:text-emerald-800',
                      isActiveHref(item.href) ? 'text-emerald-700 font-medium' : 'text-slate-700',
                    ]}
                  >{item.label}</a>
                ))}
              </div>
            </details>
          ))}
        </div>
      </nav>
    </header>
    <main class="flex-1">
      <slot />
    </main>
    <div class="border-t border-slate-200 bg-slate-50 px-4 pt-4 pb-2 text-center text-sm">
      <nav
        aria-label="Footer"
        class="flex flex-wrap items-center justify-center gap-x-3 gap-y-1 text-emerald-700"
      >
        <a
          href={navLocale === 'de' ? '/de/ueber' : '/en/about'}
          class="hover:text-emerald-800 hover:underline transition"
        >
          {t(locale, 'footer.about')}
        </a>
        <span class="text-slate-400" aria-hidden="true">{t(locale, 'footer.separator')}</span>
        <a
          href={`/${navLocale}/feedback`}
          class="hover:text-emerald-800 hover:underline transition"
        >
          {t(locale, 'feedback.nav_label')}
        </a>
        <span class="text-slate-400" aria-hidden="true">{t(locale, 'footer.separator')}</span>
        <a
          href={navLocale === 'de' ? '/de/impressum' : '/en/imprint'}
          class="hover:text-emerald-800 hover:underline transition"
        >
          {t(locale, 'footer.imprint')}
        </a>
        <span class="text-slate-400" aria-hidden="true">{t(locale, 'footer.separator')}</span>
        <a
          href={navLocale === 'de' ? '/de/datenschutz' : '/en/privacy'}
          class="hover:text-emerald-800 hover:underline transition"
        >
          {t(locale, 'footer.privacy')}
        </a>
        <span class="text-slate-400" aria-hidden="true">{t(locale, 'footer.separator')}</span>
        <a
          href={navLocale === 'de' ? '/de/bildnachweis' : '/en/image-credits'}
          class="hover:text-emerald-800 hover:underline transition"
        >
          {t(locale, 'footer.credits')}
        </a>
      </nav>
      <div class="mt-2 flex flex-wrap items-center justify-center gap-x-2 text-xs text-slate-400">
        {uiLangs.map(lng => (
          lng.code === locale
            ? <span class="font-semibold text-slate-600">{lng.label}</span>
            : <a href={lng.href} class="hover:text-emerald-700 hover:underline">{lng.label}</a>
        ))}
      </div>
    </div>
    <Disclaimer locale={locale} />
    <style>
      /* Standard-Dreieck des <summary> ausblenden — wir nutzen ein eigenes Caret-SVG */
      .nav-dd-summary { list-style: none; }
      .nav-dd-summary::-webkit-details-marker { display: none; }
      /* Caret dreht sich, wenn das Klapp-Menü offen ist */
      .nav-dd[open] > .nav-dd-summary .nav-dd-caret { transform: rotate(180deg); }
    </style>
    <script is:inline>
      // Klapp-Menüs der Kopfleiste: nur eins offen; Klick daneben + Escape schließt.
      (function () {
        var dds = Array.prototype.slice.call(document.querySelectorAll('header .nav-dd'));
        if (!dds.length) return;
        dds.forEach(function (dd) {
          dd.addEventListener('toggle', function () {
            if (dd.open) dds.forEach(function (o) { if (o !== dd) o.open = false; });
          });
        });
        document.addEventListener('click', function (e) {
          var inside = e.target && e.target.closest && e.target.closest('header .nav-dd');
          if (!inside) dds.forEach(function (o) { o.open = false; });
        });
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape') dds.forEach(function (o) { o.open = false; });
        });
      })();
    </script>
  </body>
</html>
