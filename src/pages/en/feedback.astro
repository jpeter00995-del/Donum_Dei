---
// === 1. IMPORTS ===
import BaseLayout from '@/layouts/BaseLayout.astro';
import FeedbackForm from '@/components/FeedbackForm.tsx';
import { t } from '@/lib/i18n';

// === 2. KONSTANTEN ===
const locale = 'en' as const;
---

<BaseLayout locale={locale} title="Feedback">
  <div class="max-w-2xl mx-auto px-4 py-8">
    <!-- === 1. HERO === -->
    <header class="mb-6">
      <h1 class="text-3xl font-serif font-bold text-slate-900 mb-3">
        {t(locale, 'feedback.hero_title')}
      </h1>
      <p class="text-slate-600">{t(locale, 'feedback.intro')}</p>
    </header>

    <!-- === 2. FORM === -->
    <section class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
      <FeedbackForm client:load locale={locale} />
    </section>

    <!-- === 3. FALLBACK MAILTO === -->
    <p class="mt-6 text-center text-sm text-slate-500">
      {t(locale, 'feedback.fallback_mailto')}{' '}
      <a
        href="mailto:maikelganske913@gmail.com?subject=Donum%20Dei%20Feedback"
        class="text-emerald-700 hover:text-emerald-800 underline"
      >
        {t(locale, 'feedback.fallback_mailto_link')}
      </a>
    </p>
  </div>
</BaseLayout>
