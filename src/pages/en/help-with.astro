---
// === 1. IMPORTS ===
import BaseLayout from '@/layouts/BaseLayout.astro';
import SymptomFinder from '@/components/SymptomFinder.tsx';
import { loadAllPlants } from '@/lib/loadPlants';
import { toSymptomPlant } from '@/lib/symptomCard';
import { t } from '@/lib/i18n';

// === 2. DATA ===
// Build-Zeit-Projektion auf schlanke DTO — spart ~90% Prop-Groesse im HTML.
const locale = 'en' as const;
const plants = loadAllPlants().map(toSymptomPlant);
---

<BaseLayout locale={locale} title={t(locale, 'symptoms.page_title')}>
  <article class="max-w-5xl mx-auto py-8 px-4">
    <!-- === 1. HERO === -->
    <header class="mb-8">
      <h1 class="text-3xl md:text-4xl font-serif font-bold text-slate-900">
        {t(locale, 'symptoms.page_title')}
      </h1>
      <p class="mt-3 text-base text-slate-700 leading-relaxed">
        {t(locale, 'symptoms.page_intro')}
      </p>
    </header>

    <!-- === 2. INTERACTIVE SEARCH === -->
    <SymptomFinder client:load plants={plants} locale={locale} />
  </article>
</BaseLayout>
