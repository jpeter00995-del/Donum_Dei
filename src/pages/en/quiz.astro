---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PlantQuiz from '@/components/PlantQuiz.tsx';
import { loadAllPlants } from '@/lib/loadPlants';

const plants = loadAllPlants();
const locale = 'en' as const;
---

<BaseLayout locale={locale} title="Plant Quiz">
  <div class="max-w-4xl mx-auto px-4 py-8">
    <h1 class="text-3xl font-serif font-bold text-slate-900 mb-2">Plant Quiz</h1>
    <p class="text-slate-600 mb-6">Which plant is shown in the photo? Score is stored locally.</p>
    <PlantQuiz client:only="react" plants={plants} locale={locale} />
  </div>
</BaseLayout>
