---
// === 1. IMPORTS ===
import BaseLayout from '@/layouts/BaseLayout.astro';
import PermacultureSetCard from '@/components/PermacultureSetCard.astro';
import permacultureSetsFile from '@/data/permaculture_sets.json';
import { loadAllPlants } from '@/lib/loadPlants';
import { t } from '@/lib/i18n';
import type { Plant, PermacultureSetsFile } from '@/lib/types';

// === 2. DATA ===
const locale = 'de' as const;
const setsFile = permacultureSetsFile as PermacultureSetsFile;
const sets = setsFile.sets;

const plants = loadAllPlants();
const plantBySlug = new Map<string, Plant>(plants.map(p => [p.slug, p]));
---

<BaseLayout locale={locale} title="Pflanz-Sets">
  <section class="max-w-6xl mx-auto py-8 px-4">
    <header class="mb-8">
      <h1 class="text-3xl md:text-4xl font-serif font-bold text-slate-900">
        {t(locale, 'packages.hero_title')}
      </h1>
      <p class="mt-3 text-lg text-slate-700 max-w-3xl">
        {t(locale, 'packages.hero_intro')}
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {sets.map(set => (
        <PermacultureSetCard set={set} locale={locale} plantBySlug={plantBySlug} />
      ))}
    </div>
  </section>

  <script>
    // Hash-Restore: nach kurzer Hydration-Pause zur Karte scrollen
    // (sonst springt der Browser zu früh — vor Hydration der Inseln).
    if (typeof window !== 'undefined' && window.location.hash) {
      const id = window.location.hash.slice(1);
      window.requestAnimationFrame(() => {
        const el = document.getElementById(id);
        if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    }
  </script>
</BaseLayout>
