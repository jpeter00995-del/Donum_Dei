---
import BaseLayout from '@/layouts/BaseLayout.astro';
import FilterBar from '@/components/FilterBar.tsx';
import { getPlantsSortedByLocale } from '@/lib/loadPlants';
import { isControlled } from '@/lib/speciesFilters';
import { toPlantCard } from '@/lib/plantCard';

const locale = 'de' as const;
// Nur rechtlich kontrollierte/psychoaktive Arten (legal_status.controlled === true) —
// Pflanzen UND Pilze (Cross-Listing: kontrollierte Pilze stehen auch auf /de/pilze).
const controlled = getPlantsSortedByLocale(locale).filter(isControlled).map(toPlantCard);
---

<BaseLayout locale={locale} title="Rauschpflanzen & psychoaktive Pilze — Donum Dei">
  <div class="max-w-6xl mx-auto px-4 py-8">
    <h1 class="text-2xl md:text-3xl font-serif font-bold text-slate-900 mb-2">🌀 Rauschpflanzen &amp; psychoaktive Pilze</h1>
    <p class="text-slate-600 mb-4 max-w-2xl">
      Diese Arten stehen wegen psychoaktiver Wirkstoffe ganz oder teilweise unter rechtlicher
      Kontrolle — Pflanzen wie Pilze. Die Einträge sind rein botanisch-historisch und edukativ:
      Herkunft, Wirkstoffe, Kulturgeschichte und Sicherheits-Hinweise, quellenbelegt.
    </p>
    <p class="text-sm text-amber-800 bg-amber-50 border border-amber-200 rounded-lg px-4 py-3 mb-6 max-w-2xl">
      <strong>Keine Konsum-, Dosis- oder Anbauanleitung.</strong> Die Rechtslage ist je nach Land sehr
      unterschiedlich — auf jeder Detailseite findest du einen gesonderten Rechts-Hinweis. Informiere
      dich über die für dich geltende Rechtslage.
    </p>
    <FilterBar client:load plants={controlled} locale={locale} noun="controlled" />
  </div>
</BaseLayout>
