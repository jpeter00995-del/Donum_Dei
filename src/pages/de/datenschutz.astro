---
// === 1. IMPORTS ===
import BaseLayout from '@/layouts/BaseLayout.astro';

// === 2. KONSTANTEN ===
const locale = 'de' as const;
---

<BaseLayout locale={locale} title="Datenschutz">
  <div class="max-w-3xl mx-auto px-4 py-8 prose prose-slate">
    <!-- === 1. HERO === -->
    <header class="mb-6">
      <h1 class="text-3xl font-serif font-bold text-slate-900 mb-2">Datenschutzerklärung</h1>
      <p class="text-sm text-slate-500">
        Stand: 2026-06-24 ·
        <a href="/de/impressum" class="text-emerald-700 hover:text-emerald-800 underline">Verantwortlich: siehe Impressum</a>
      </p>
    </header>

    <!-- === 2. WELCHE DATEN === -->
    <section class="mb-8">
      <h2 class="text-xl font-serif font-semibold text-slate-900 mb-3">1. Welche Daten werden verarbeitet?</h2>

      <h3 class="text-lg font-semibold text-slate-900 mt-4 mb-2">Im Browser gespeichert (LocalStorage)</h3>
      <p class="text-slate-700 leading-relaxed">
        Bei der Nutzung des Garten-Planers werden folgende Daten
        <strong>ausschließlich in Deinem Browser</strong> gespeichert — sie
        verlassen Dein Gerät NICHT:
      </p>
      <ul class="list-disc pl-6 mt-2 text-slate-700 leading-relaxed">
        <li>Klimazone, Garten-Typ (Hochbeet/Balkon/Feld/Gewächshaus), Garten-Größe</li>
        <li>Haushaltsgröße, Selbstversorgungs-Ziel, Erfahrungslevel</li>
        <li>Deine ausgewählten Pflanzen mit Mengen</li>
        <li>Deine Beet-Positionen (Drag&amp;Drop-Anordnung)</li>
      </ul>
      <p class="text-slate-700 leading-relaxed mt-2">
        Du kannst diese Daten jederzeit löschen via „Profil zurücksetzen" auf
        der Mein-Garten-Seite oder über die Browser-Einstellungen (Cache leeren).
      </p>

      <h3 class="text-lg font-semibold text-slate-900 mt-6 mb-2">Beim Senden von Feedback (optional, freiwillig)</h3>
      <p class="text-slate-700 leading-relaxed">
        Wenn Du die Feedback-Form nutzt, werden Deine Eingaben (Kategorie,
        optional Pflanze-Slug, Nachricht, optional Deine Email) an den
        Drittanbieter-Dienst <strong>Web3Forms</strong> (Saik3D Technologies LLC,
        USA) übermittelt, der die Nachricht an Maikels Email weiterleitet.
        Web3Forms speichert Submissions 30 Tage für Spam-Filterung, danach
        Löschung. Web3Forms-Datenschutz:
        <a
          href="https://web3forms.com/privacy"
          class="text-emerald-700 hover:text-emerald-800 underline"
          rel="noopener noreferrer"
          target="_blank"
        >https://web3forms.com/privacy</a>
      </p>

      <h3 class="text-lg font-semibold text-slate-900 mt-6 mb-2">Server-Logs (Cloudflare Pages)</h3>
      <p class="text-slate-700 leading-relaxed">
        Beim Aufruf der Seite verarbeitet unser Hoster Cloudflare Pages
        technisch notwendige Daten (IP-Adresse, User-Agent, Request-URL,
        Zeitstempel). Diese werden für Sicherheit + Performance verwendet
        (Schutz vor Angriffen, Caching). Cloudflare-Datenschutz:
        <a
          href="https://www.cloudflare.com/de-de/privacypolicy/"
          class="text-emerald-700 hover:text-emerald-800 underline"
          rel="noopener noreferrer"
          target="_blank"
        >https://www.cloudflare.com/de-de/privacypolicy/</a>
      </p>

      <h3 class="text-lg font-semibold text-slate-900 mt-6 mb-2">Externe Inhalte</h3>
      <p class="text-slate-700 leading-relaxed">
        Pflanzen-Bilder und -Texte stammen von <strong>Wikipedia, Wikimedia
        Commons, GBIF</strong>. Diese sind beim Build der Seite einmalig
        eingebunden — bei Deinem Besuch werden KEINE Live-Anfragen an diese
        Dienste gestellt.
      </p>

      <h3 class="text-lg font-semibold text-slate-900 mt-6 mb-2">Interaktive Karten (OpenStreetMap)</h3>
      <p class="text-slate-700 leading-relaxed">
        Auf Seiten mit einer interaktiven Karte (z. B. der Karten-Seite oder
        Pflanzen-Seiten mit Verbreitungsdaten) lädt Dein Browser die
        Karten-Kacheln <strong>live</strong> von den Servern der
        <strong>OpenStreetMap Foundation</strong>. Dabei erhält OpenStreetMap
        technisch notwendige Daten — insbesondere Deine IP-Adresse —, um die
        Kacheln auszuliefern. Das geschieht nur auf Seiten mit Karte; der Rest
        der Seite stellt keine solchen Anfragen, und es werden dabei keine
        Werbe-Cookies gesetzt. OpenStreetMap-Datenschutz:
        <a
          href="https://wiki.osmfoundation.org/wiki/Privacy_Policy"
          class="text-emerald-700 hover:text-emerald-800 underline"
          rel="noopener noreferrer"
          target="_blank"
        >https://wiki.osmfoundation.org/wiki/Privacy_Policy</a>
      </p>

      <h3 class="text-lg font-semibold text-slate-900 mt-6 mb-2">Werbung (Google AdSense)</h3>
      <p class="text-slate-700 leading-relaxed">
        Diese Seite finanziert sich teilweise über Anzeigen von
        <strong>Google AdSense</strong> (Google Ireland Ltd.). Dafür wird auf den
        Seiten Google-Code geladen, der Cookies setzen und Daten — u. a. Deine
        IP-Adresse sowie Geräte- und Nutzungsinformationen — verarbeiten kann, um
        Anzeigen auszuliefern, zu messen und vor Missbrauch zu schützen.
        In der EU holt Google vor personalisierter Werbung über einen eigenen
        Einwilligungs-Banner Deine Zustimmung ein. Du kannst ablehnen — dann
        werden nur nicht-personalisierte Anzeigen ausgespielt. Wie Google Daten
        im Rahmen von Werbung verarbeitet:
        <a
          href="https://policies.google.com/technologies/ads"
          class="text-emerald-700 hover:text-emerald-800 underline"
          rel="noopener noreferrer"
          target="_blank"
        >https://policies.google.com/technologies/ads</a>
      </p>

      <h3 class="text-lg font-semibold text-slate-900 mt-6 mb-2">Foto-Erkennung (optional, freiwillig)</h3>
      <p class="text-slate-700 leading-relaxed">
        Nur wenn Du auf der Suchseite die Funktion „Per Foto bestimmen" aktiv
        nutzt, wird Dein Foto über unsere Server-Funktion an den
        Drittanbieter-Dienst <strong>Pl@ntNet</strong> (Cirad/INRAE/IRD/Inria,
        Frankreich/EU) übertragen, um die Pflanze zu bestimmen. Das Bild wird
        vor dem Senden in Deinem Browser verkleinert; dabei werden
        <strong>EXIF-Metadaten (inkl. GPS-Standort) entfernt</strong>. Wir
        speichern Deine Fotos nicht. Pl@ntNet-Datenschutz:
        <a
          href="https://plantnet.org/en/legal-notice/"
          class="text-emerald-700 hover:text-emerald-800 underline"
          rel="noopener noreferrer"
          target="_blank"
        >https://plantnet.org/en/legal-notice/</a>
      </p>
    </section>

    <!-- === 3. KEINE TRACKER === -->
    <section class="mb-8">
      <h2 class="text-xl font-serif font-semibold text-slate-900 mb-3">2. Cookies, Tracking und Werbung</h2>
      <p class="text-slate-700 leading-relaxed">
        Donum Dei selbst verwendet <strong>KEIN</strong> eigenes Analytics,
        KEINEN Facebook-Pixel, KEINE Social-Media-Plugins und KEINE externen
        Schriften. Cookies und eine Daten-Verarbeitung können nur durch zwei
        eingebundene Dienste entstehen: <strong>Google AdSense</strong> (Werbung,
        siehe oben) und die <strong>OpenStreetMap</strong>-Karten (siehe oben).
        Ohne diese beiden Funktionen ist die Seite frei von Tracking. Deine
        Garten-Daten bleiben in jedem Fall ausschließlich lokal auf Deinem Gerät.
      </p>
    </section>

    <!-- === 4. DSGVO-RECHTE === -->
    <section class="mb-8">
      <h2 class="text-xl font-serif font-semibold text-slate-900 mb-3">3. Deine Rechte (DSGVO)</h2>
      <ul class="list-disc pl-6 text-slate-700 leading-relaxed">
        <li><strong>Auskunft</strong> über gespeicherte Daten (Art. 15 DSGVO)</li>
        <li><strong>Berichtigung</strong> unrichtiger Daten (Art. 16)</li>
        <li><strong>Löschung</strong> Deiner Daten (Art. 17)</li>
        <li><strong>Einschränkung</strong> der Verarbeitung (Art. 18)</li>
        <li><strong>Datenübertragbarkeit</strong> (Art. 20)</li>
        <li><strong>Widerspruch</strong> gegen Verarbeitung (Art. 21)</li>
        <li><strong>Beschwerde</strong> bei der Aufsichtsbehörde</li>
      </ul>
      <p class="text-slate-700 leading-relaxed mt-3">
        Anfragen an:
        <a
          href="mailto:maikelganske913@gmail.com"
          class="text-emerald-700 hover:text-emerald-800 underline"
        >maikelganske913@gmail.com</a>
      </p>
    </section>

    <!-- === 5. AENDERUNGEN === -->
    <section class="mb-8">
      <h2 class="text-xl font-serif font-semibold text-slate-900 mb-3">4. Änderungen</h2>
      <p class="text-slate-700 leading-relaxed">
        Diese Erklärung kann sich bei technischen Änderungen anpassen. Aktuelle
        Version immer auf dieser Seite.
      </p>
    </section>
  </div>
</BaseLayout>
