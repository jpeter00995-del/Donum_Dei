---
// === 1. PAGE-SETUP ===
import BaseLayout from '@/layouts/BaseLayout.astro';
import { t } from '@/lib/i18n';
import { loadAllPlants } from '@/lib/loadPlants';
import { buildLatinIndex } from '@/lib/plantMatch';
import PlantIdentifier from '@/components/PlantIdentifier.tsx';
import PlantNetAttribution from '@/components/PlantNetAttribution.astro';

const locale = 'de' as const;
const title = t(locale, 'search.title');

// Latin→Slug-Index zur Build-Zeit (Muster wie kalender.astro) — schlankes DTO ans Island.
const latinIndex = buildLatinIndex(loadAllPlants());
---

<BaseLayout locale={locale} title={title}>
  <div class="max-w-4xl mx-auto px-4 py-8">
    <h1 class="font-serif text-3xl sm:text-4xl font-bold text-slate-900 mb-3">
      🔍 {t(locale, 'search.title')}
    </h1>
    <p class="text-slate-600 mb-6 leading-relaxed">{t(locale, 'search.intro')}</p>

    <!-- === 2. PAGEFIND UI === -->
    <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
    <div id="pagefind-search" class="mb-8"></div>
    <script src="/pagefind/pagefind-ui.js" is:inline></script>
    <script is:inline>
      window.addEventListener('DOMContentLoaded', () => {
        // @ts-ignore — PagefindUI ist Global aus pagefind-ui.js
        const ui = new PagefindUI({
          element: '#pagefind-search',
          showSubResults: true,
          pageSize: 10,
          resetStyles: false,
          showImages: false,
          excerptLength: 25,
          forceLanguage: 'de',
          translations: {
            placeholder: 'Pflanze, Symptom, Inhaltsstoff…',
            clear_search: 'Suche löschen',
            load_more: 'Mehr Ergebnisse',
            search_label: 'Pflanzendatenbank durchsuchen',
            filters_label: 'Filter',
            zero_results: 'Keine Treffer für [SEARCH_TERM]',
            many_results: '[COUNT] Treffer für [SEARCH_TERM]',
            one_result: '[COUNT] Treffer für [SEARCH_TERM]',
            alt_search: 'Keine Treffer für [SEARCH_TERM]. Stattdessen: [DIFFERENT_TERM]',
            search_suggestion: 'Keine Treffer für [SEARCH_TERM]. Versuche: [DIFFERENT_TERM]',
            searching: 'Suche nach [SEARCH_TERM]…'
          }
        });
        // Suchbegriff aus der URL (?q=...) — macht SearchAction/Direktlinks funktionsfähig.
        const q = new URLSearchParams(window.location.search).get('q');
        if (q) ui.triggerSearch(q);
      });
    </script>

    <!-- === 3. BEISPIEL-SUCHEN === -->
    <div class="border-t border-slate-200 pt-4 text-sm text-slate-500">
      <p class="font-semibold text-slate-700 mb-1">{t(locale, 'search.examples_title')}</p>
      <p>{t(locale, 'search.examples')}</p>
    </div>

    <!-- === 4. FOTO-ERKENNUNG === -->
    <section class="mt-10 border-t border-slate-200 pt-8">
      <h2 class="font-serif text-2xl font-bold text-slate-900 mb-2">
        📷 {t(locale, 'identify.title')}
      </h2>
      <p class="text-slate-600 mb-4 leading-relaxed">{t(locale, 'identify.intro')}</p>
      <PlantIdentifier client:visible locale={locale} latinIndex={latinIndex} />
      <PlantNetAttribution locale={locale} />
    </section>
  </div>
</BaseLayout>

<style>
  /* === 4. PAGEFIND-UI-OVERRIDES (Donum-Dei-Farbschema) === */
  :global(:root) {
    --pagefind-ui-primary: #047857;
    --pagefind-ui-text: #0f172a;
    --pagefind-ui-background: #ffffff;
    --pagefind-ui-border: #e2e8f0;
    --pagefind-ui-tag: #f1f5f9;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 8px;
    --pagefind-ui-font: 'Inter', system-ui, sans-serif;
  }
</style>
