---
import BaseLayout from '@/layouts/BaseLayout.astro';
import FilterBar from '@/components/FilterBar.tsx';
import { getPlantsSortedByLocale } from '@/lib/loadPlants';
import { t } from '@/lib/i18n';

const locale = 'de' as const;
const plants = getPlantsSortedByLocale(locale);
---

<BaseLayout locale={locale}>
  <div class="max-w-6xl mx-auto px-4 py-8">
    <h1 class="text-2xl md:text-3xl font-serif font-bold text-slate-900 mb-6">{t(locale, 'site.tagline')}</h1>
    <FilterBar client:load plants={plants} locale={locale} />
  </div>
</BaseLayout>
