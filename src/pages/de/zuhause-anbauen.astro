---
// === 1. IMPORTS ===
import BaseLayout from '@/layouts/BaseLayout.astro';
import IndoorFilterBar from '@/components/IndoorFilterBar';
import IndoorQuiz from '@/components/IndoorQuiz';
import { loadIndoorPlants } from '@/lib/loadPlants';
import { t } from '@/lib/i18n';

// === 2. DATA ===
const locale = 'de' as const;
const plants = loadIndoorPlants();
---

<BaseLayout locale={locale} title={t(locale, 'indoor.title')}>
  <section class="max-w-6xl mx-auto py-8 px-4">
    <h1 class="text-3xl font-serif font-bold text-emerald-800 mb-4">
      🪴 {t(locale, 'indoor.title')}
    </h1>
    <p class="text-lg text-gray-700 mb-4">{t(locale, 'indoor.hero')}</p>
    <p class="text-sm text-gray-500 mb-8">
      {plants.length} Pflanzen, sortiert nach Schwierigkeit
    </p>
    <div class="mb-8">
      <IndoorQuiz plants={plants} locale={locale} client:load />
    </div>
    <IndoorFilterBar plants={plants} locale={locale} client:load />
  </section>
</BaseLayout>
