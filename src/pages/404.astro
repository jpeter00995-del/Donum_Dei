---
// === Eigene 404-Seite (zweisprachig — wird für alle nicht gefundenen URLs ausgeliefert) ===
import BaseLayout from '@/layouts/BaseLayout.astro';
const locale = 'de' as const;
---

<BaseLayout locale={locale} title="Seite nicht gefunden / Page not found">
  <section class="max-w-2xl mx-auto px-4 py-16 text-center">
    <p class="text-6xl mb-4" aria-hidden="true">🌿</p>
    <h1 class="text-3xl md:text-4xl font-serif font-bold text-slate-900 mb-3">
      Seite nicht gefunden
    </h1>
    <p class="text-slate-700 mb-1">
      Diese Seite gibt es nicht (mehr). Vielleicht hilft die Suche oder die Startseite weiter.
    </p>
    <p class="text-slate-500 text-sm mb-8">
      Page not found — try the search or head back to the start page.
    </p>

    <div class="flex flex-wrap justify-center gap-3">
      <a
        href="/de/"
        class="inline-flex items-center px-5 py-2.5 rounded-md bg-emerald-600 text-white font-medium hover:bg-emerald-700 transition"
      >
        🌱 Zu den Pflanzen
      </a>
      <a
        href="/de/suche"
        class="inline-flex items-center px-5 py-2.5 rounded-md border border-slate-300 text-slate-700 font-medium hover:bg-slate-50 transition"
      >
        🔍 Suche
      </a>
      <a
        href="/en/"
        class="inline-flex items-center px-5 py-2.5 rounded-md border border-slate-300 text-slate-700 font-medium hover:bg-slate-50 transition"
      >
        🇬🇧 English version
      </a>
    </div>
  </section>
</BaseLayout>
