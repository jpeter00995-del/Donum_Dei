# === Cloudflare Pages — HTTP-Header ===
# Wird beim Build nach dist/ kopiert und von Cloudflare Pages ausgeliefert.
# Mehrere passende Regeln werden kombiniert (spätere/​speziellere gewinnen bei Konflikt).

# 1. Fingerprinted Assets (Dateiname enthält Hash) → 1 Jahr unveränderlich cachen.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/pagefind/*
  Cache-Control: public, max-age=31536000, immutable

# 2. Bilder (stabile Namen, ändern sich selten) → 30 Tage cachen, aber nicht "immutable".
/images/*
  Cache-Control: public, max-age=2592000

# 3. Security-Header für alle Seiten.
#    (CSP bewusst NOCH NICHT hier — kommt später separat im Report-Only-Modus,
#     weil AdSense + Inline-Scripts sorgfältig erlaubt werden müssen.)
/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
